    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jsonrepair": "^3.14.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.52.7",
    "playwright": "^1.60.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "uuid": "^14.0.0",
    "vite": "^8.0.10",
    "zod": "^3.23.8",
    "zustand": "^5.0.12"
