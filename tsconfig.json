{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "allowImportingTsExtensions": true,
    "noEmit": true,

    "paths": {
      "core/*": ["core/*"],
      "shared/*": ["shared/*"]
    },
  },
  "exclude": ["node_modules", "dist"],
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}
