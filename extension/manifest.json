{
  "manifest_version": 3,
  "name": "TradingView Capture Pipeline",
  "version": "1.0",
  "description": "Capture multiple timeframes from TradingView automatically.",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://*.tradingview.com/*",
    "http://localhost:3000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Capture All TF"
  }
}
